{
    "name": "shipmonk/packing",
    "description": "Packing calculation microservice",
    "require": {
        "ext-pdo": "*",
        "ext-json": "*",
        "php": ">=8.4",
        "psr/http-message": "2.*",
        "psr/log": "^3.0",
        "guzzlehttp/guzzle": "^7.9",
        "guzzlehttp/psr7": "2.*",
        "doctrine/orm": "3.*",
        "symfony/cache": "7.*",
        "symfony/var-exporter": "7.*",
        "symfony/validator": "7.*",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.7",
        "ramsey/uuid-doctrine": "^2.1",
        "symfony/uid": "7.*",
        "symfony/dependency-injection": "7.*",
        "symfony/config": "7.*",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "dg/bypass-finals": "^1.9",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
